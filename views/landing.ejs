<%- include('partials/header') %>

<!-- Hero -->
<section class="hero-section text-white text-center py-20 px-4">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-4xl sm:text-5xl font-extrabold mb-4 leading-tight"><%= t('heroTitle') %></h1>
    <p class="text-lg sm:text-xl opacity-90 mb-8 max-w-xl mx-auto"><%= t('heroSub') %></p>
    <a href="/auth/google" class="inline-flex items-center gap-3 bg-white text-gray-800 font-semibold text-lg px-8 py-4 rounded-xl shadow-lg hover:shadow-xl hover:scale-105 transition transform">
      <svg width="24" height="24" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      <%= t('ctaLogin') %>
    </a>
  </div>
</section>

<!-- Features -->
<section class="max-w-5xl mx-auto px-4 py-16">
  <div class="grid md:grid-cols-3 gap-8">
    <div class="feature-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md hover:shadow-lg transition">
      <div class="text-4xl mb-4">&#x1F514;</div>
      <h3 class="text-xl font-bold mb-2"><%= t('feature1Title') %></h3>
      <p class="text-gray-500 dark:text-gray-400"><%= t('feature1Desc') %></p>
    </div>
    <div class="feature-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md hover:shadow-lg transition">
      <div class="text-4xl mb-4">&#x1F4CA;</div>
      <h3 class="text-xl font-bold mb-2"><%= t('feature2Title') %></h3>
      <p class="text-gray-500 dark:text-gray-400"><%= t('feature2Desc') %></p>
    </div>
    <div class="feature-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md hover:shadow-lg transition">
      <div class="text-4xl mb-4">&#x1F3AF;</div>
      <h3 class="text-xl font-bold mb-2"><%= t('feature3Title') %></h3>
      <p class="text-gray-500 dark:text-gray-400"><%= t('feature3Desc') %></p>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="bg-white dark:bg-gray-800 py-16 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-10"><%= t('howItWorks') %></h2>
    <div class="grid sm:grid-cols-3 gap-8">
      <div>
        <div class="w-14 h-14 bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center text-2xl font-bold text-indigo-600 dark:text-indigo-300 mx-auto mb-4">1</div>
        <p class="font-medium"><%= t('step1') %></p>
      </div>
      <div>
        <div class="w-14 h-14 bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center text-2xl font-bold text-indigo-600 dark:text-indigo-300 mx-auto mb-4">2</div>
        <p class="font-medium"><%= t('step2') %></p>
      </div>
      <div>
        <div class="w-14 h-14 bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center text-2xl font-bold text-indigo-600 dark:text-indigo-300 mx-auto mb-4">3</div>
        <p class="font-medium"><%= t('step3') %></p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
